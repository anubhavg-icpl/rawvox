# =========================================================
# RawVox — environment template
# Copy to .env and fill in. Both `docker compose build` and
# `docker compose up` read this file automatically.
# =========================================================

# Hugging Face token (free). Required to avoid HF Hub rate limits
# during model downloads (Kokoro, sentence-transformers, whisper).
# Read scope is sufficient. https://huggingface.co/settings/tokens
HF_TOKEN=

# SearXNG instance secret. Generate with `openssl rand -hex 32`.
SEARXNG_SECRET=
